{
  "name": "Rust Industrial Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#1f1f1f",
    "editor.foreground": "#e0e0e0",
    "sideBar.background": "#1a1a1a",
    "activityBar.background": "#1a1a1a",
    "activityBar.foreground": "#ff4d29",
    "statusBar.background": "#262626",
    "statusBar.foreground": "#ff4d29",
    "statusBar.border": "#333333",

    "editorCursor.foreground": "#ff4d29",
    "editor.selectionBackground": "#444444",
    "editor.lineHighlightBackground": "#262626",
    "editorLineNumber.activeForeground": "#ff4d29",

    "tab.activeBackground": "#1f1f1f",
    "tab.activeForeground": "#ff4d29",
    "tab.inactiveBackground": "#1a1a1a",
    "tab.border": "#333333",

    "terminal.background": "#1f1f1f",
    "terminal.foreground": "#e0e0e0",
    "terminal.ansiBlack": "#262626",
    "terminal.ansiRed": "#ff4d29",
    "terminal.ansiGreen": "#98971a",
    "terminal.ansiYellow": "#fabd2f",
    "terminal.ansiBlue": "#83a598",
    "terminal.ansiMagenta": "#d3869b",
    "terminal.ansiCyan": "#8ec07c",
    "terminal.ansiWhite": "#e0e0e0",
    "terminal.ansiBrightBlack": "#666666",
    "terminal.ansiBrightRed": "#f74c00",
    "terminal.ansiBrightGreen": "#b5bd68",
    "terminal.ansiBrightYellow": "#f2e5bc",

    "editorBracketHighlight.foreground1": "#fabd2f",
    "editorBracketHighlight.foreground2": "#8fb28f",
    "editorBracketHighlight.foreground3": "#d3869b",
    "editorBracketHighlight.foreground4": "#83a598",
    "editorBracketHighlight.foreground5": "#ff4d29",
    "editorBracketHighlight.foreground6": "#f2e5bc",
    "editorBracketHighlight.unexpectedBracket.foreground": "#ff0000",

    "editorError.foreground": "#ff4d29",
    "editorWarning.foreground": "#fabd2f",
    "editorInfo.foreground": "#83a598",
    "editorHint.foreground": "#8fb28f",
    "problemsErrorIcon.foreground": "#ff4d29",
    "problemsWarningIcon.foreground": "#fabd2f",

    "gitDecoration.modifiedResourceForeground": "#fabd2f",
    "gitDecoration.deletedResourceForeground": "#ff4d29",
    "gitDecoration.untrackedResourceForeground": "#98971a",
    "gitDecoration.ignoredResourceForeground": "#666666",

    "editorRuler.foreground": "#333333",
    "scrollbarSlider.background": "#44444450",
    "scrollbarSlider.hoverBackground": "#66666680",
    "scrollbarSlider.activeBackground": "#ff4d2980"
  },
  "tokenColors": [
    {
      "name": "Keywords e Estruturas de Controle",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.control"
      ],
      "settings": { "foreground": "#ff4d29" }
    },
    {
      "name": "Funções e Métodos",
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function"
      ],
      "settings": { "foreground": "#f2e5bc" }
    },
    {
      "name": "Strings e Caracteres",
      "scope": ["string", "constant.character"],
      "settings": { "foreground": "#98971a" }
    },
    {
      "name": "Tipos, Structs e Enums",
      "scope": ["entity.name.type", "support.type", "support.class"],
      "settings": { "foreground": "#fabd2f" }
    },
    {
      "name": "Números e Constantes",
      "scope": ["constant.numeric", "constant.language", "support.constant"],
      "settings": { "foreground": "#d3869b" }
    },
    {
      "name": "Comentários",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#666666", "fontStyle": "italic" }
    },
    {
      "name": "Macros (Rust)",
      "scope": ["entity.name.function.macro", "support.function.macro"],
      "settings": { "foreground": "#8fb28f", "fontStyle": "bold" }
    },
    {
      "name": "Lifetimes (Rust)",
      "scope": ["storage.modifier.lifetime", "entity.name.type.lifetime"],
      "settings": { "foreground": "#d3869b", "fontStyle": "italic" }
    },
    {
      "name": "TOML: Tabelas e Seções",
      "scope": [
        "entity.name.section.toml",
        "support.type.property-name.table.toml",
        "meta.tag.toml"
      ],
      "settings": {
        "foreground": "#fabd2f",
        "fontStyle": "bold"
      }
    },
    {
      "name": "TOML: Chaves (Keys)",
      "scope": [
        "variable.key.toml",
        "support.type.property-name.toml",
        "keyword.key.toml"
      ],
      "settings": {
        "foreground": "#83a598"
      }
    },
    {
      "name": "TOML: Pontuação",
      "scope": [
        "punctuation.definition.table.toml",
        "punctuation.separator.key-value.toml"
      ],
      "settings": {
        "foreground": "#666666"
      }
    },
    {
      "name": "Markdown: Títulos (Headings)",
      "scope": ["markup.heading", "punctuation.definition.heading.markdown"],
      "settings": { "foreground": "#fabd2f", "fontStyle": "bold" }
    },
    {
      "name": "Markdown: Negrito e Itálico",
      "scope": ["markup.bold", "punctuation.definition.bold.markdown"],
      "settings": { "foreground": "#ff4d29", "fontStyle": "bold" }
    },
    {
      "name": "Markdown: Itálico",
      "scope": ["markup.italic", "punctuation.definition.italic.markdown"],
      "settings": { "foreground": "#d3869b", "fontStyle": "italic" }
    },
    {
      "name": "Markdown: Listas e Citações (Blockquote)",
      "scope": [
        "markup.quote",
        "markup.list",
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": { "foreground": "#98971a" }
    },
    {
      "name": "Markdown: Links e Texto de Link",
      "scope": ["markup.underline.link", "string.other.link.title.markdown"],
      "settings": { "foreground": "#83a598", "fontStyle": "underline" }
    },
    {
      "name": "Markdown: Código Inline (Crases)",
      "scope": [
        "markup.inline.raw.string.markdown",
        "markup.fenced_code.block.markdown"
      ],
      "settings": { "foreground": "#f2e5bc" }
    },
    {
      "name": "HTML/Markdown: Tags HTML",
      "scope": ["entity.name.tag", "meta.tag.sgml"],
      "settings": { "foreground": "#fabd2f" }
    },
    {
      "name": "HTML/Markdown: Pontuação de Tags (< e >)",
      "scope": ["punctuation.definition.tag"],
      "settings": { "foreground": "#666666" }
    },
    {
      "name": "HTML/Markdown: Atributos da Tag",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#83a598", "fontStyle": "italic" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable.mut:rust": { "fontStyle": "underline" },
    "lifetime:rust": { "foreground": "#d3869b", "fontStyle": "italic" },
    "macro:rust": { "foreground": "#8fb28f", "fontStyle": "bold" }
  }
}
